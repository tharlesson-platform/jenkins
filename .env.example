# ---------------------------------------------------------------------------
# Geral
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=jenkins-platform
TZ=America/Sao_Paulo

# ---------------------------------------------------------------------------
# Controller Jenkins
# ---------------------------------------------------------------------------
JENKINS_VERSION=lts-jdk21
JENKINS_HTTP_PORT=8080
JENKINS_AGENT_PORT=50000
JENKINS_URL=http://localhost:8080
JENKINS_INTERNAL_URL=http://jenkins-controller:8080
JENKINS_EXECUTORS=0
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=change_me_now
CASC_RELOAD_TOKEN=change_me_reload_token
JENKINS_JAVA_OPTS=-Xms512m -Xmx2048m -Djenkins.install.runSetupWizard=false
SHARED_LIBRARY_NAME=jenkins-shared-lib
SHARED_LIBRARY_DEFAULT_VERSION=main
SHARED_LIBRARY_REPO_URL=https://github.com/example/jenkins-platform.git
SHARED_LIBRARY_CREDENTIALS_ID=
SEED_DEFAULT_REPO_URL=https://github.com/example/jenkins-platform.git
SEED_DEFAULT_BRANCH=main

# Active Directory
AD_DOMAIN=example.local
AD_SERVERS=ad01.example.local:3268,ad02.example.local:3268
AD_BIND_DN=CN=svc_jenkins,OU=Service Accounts,DC=example,DC=local
AD_BIND_PASSWORD=change_me_bind_password
AD_SITE=
AD_USER_SEARCH_BASE=OU=Users,DC=example,DC=local
AD_GROUP_SEARCH_BASE=OU=Groups,DC=example,DC=local
AD_USER_SEARCH_FILTER=(sAMAccountName={0})
AD_GROUP_SEARCH_FILTER=(member={0})
AD_GROUP_ADMINS=jenkins-admins
AD_GROUP_DEVELOPERS=jenkins-developers
AD_GROUP_READONLY=jenkins-readonly
AD_GROUP_RELEASE_MANAGERS=jenkins-release-managers

# ---------------------------------------------------------------------------
# Agents (opcional)
# ---------------------------------------------------------------------------
INBOUND_AGENT_TAG=latest-jdk21
AGENT_IMAGE_TAG=latest
AGENT_MAX_WAIT_SECONDS=300
GRADLE_VERSION=8.10.2
NODE_MAJOR=22
GO_VERSION=1.24.1
GOLANGCI_LINT_VERSION=v1.61.0
KUBECTL_VERSION=v1.31.3
HELM_VERSION=v3.16.3
YQ_VERSION=v4.44.5
INSTALL_AWSCLI=false

# Segredos explicitos opcionais dos agents (vazio = busca automatica via API Jenkins)
AGENT_JAVA_SECRET=
AGENT_PYTHON_SECRET=
AGENT_NODE_SECRET=
AGENT_GO_SECRET=
AGENT_DOCKER_SECRET=
AGENT_KUBERNETES_SECRET=

# ---------------------------------------------------------------------------
# SonarQube
# ---------------------------------------------------------------------------
SONARQUBE_PORT=9000
SONARQUBE_JDBC_USERNAME=sonar
SONARQUBE_JDBC_PASSWORD=sonar
POSTGRES_DB=sonar
POSTGRES_USER=sonar
POSTGRES_PASSWORD=sonar
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Nexus
# ---------------------------------------------------------------------------
NEXUS_PORT=8081
NEXUS_DOCKER_PORT=8082
NEXUS_CONTEXT_PATH=/

# ---------------------------------------------------------------------------
# Reverse proxy opcional
# ---------------------------------------------------------------------------
NGINX_HTTP_PORT=80

# ---------------------------------------------------------------------------
# Defaults de scan de seguranca
# ---------------------------------------------------------------------------
TRIVY_SEVERITY=HIGH,CRITICAL
TRIVY_IGNORE_UNFIXED=true
TRIVY_TIMEOUT=10m

# ---------------------------------------------------------------------------
# Comportamento de build Docker
# ---------------------------------------------------------------------------
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ---------------------------------------------------------------------------
# Placeholders opcionais para credentials.example.yaml
# ---------------------------------------------------------------------------
NEXUS_CI_USER=nexus-ci
NEXUS_CI_PASSWORD=change_me
REGISTRY_USER=change_me
REGISTRY_PASSWORD=change_me
AWS_ACCESS_KEY_ID=change_me
AWS_SECRET_ACCESS_KEY=change_me
SSH_DEPLOY_USER=jenkins
SSH_DEPLOY_PRIVATE_KEY=change_me
KUBECONFIG_B64=change_me_base64

